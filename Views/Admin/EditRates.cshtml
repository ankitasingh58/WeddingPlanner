@model Wedding_Planner.Models.AmentiesMaster
@{
    ViewBag.Title = "EditRates";
    Layout = "~/Views/Shared/Admin_Layout.cshtml";
}

<div class="card" style="max-width: 700px; margin: auto;">
    <div class="header">
        <h4 class="title">Update Pricing: <span class="text-primary">@Model.EventName</span></h4>
    </div>
    <div class="content">
        @using (Html.BeginForm("EditRates", "Admin", FormMethod.Post))
        {
            @Html.HiddenFor(m => m.EventName) <div class="row">
                <div class="col-md-6">
                    <label>Lawn Rate</label>
                    @Html.TextBoxFor(m => m.Laun, new { @class = "form-control", type = "number" })
                </div>
                <div class="col-md-6">
                    <label>Hall Rate</label>
                    @Html.TextBoxFor(m => m.Hall, new { @class = "form-control", type = "number" })
                </div>
            </div>
            <br />
            <div class="row">
                <div class="col-md-4">
                    <label>Music</label>
                    @Html.TextBoxFor(m => m.Music, new { @class = "form-control", type = "number" })
                </div>
                <div class="col-md-4">
                    <label>Tent</label>
                    @Html.TextBoxFor(m => m.Tent, new { @class = "form-control", type = "number" })
                </div>
                <div class="col-md-4">
                    <label>Catering</label>
                    @Html.TextBoxFor(m => m.Catering, new { @class = "form-control", type = "number" })
                </div>
            </div>
            <br />
            <button type="submit" class="btn btn-info btn-fill pull-right">Update Price List</button>
            <div class="clearfix"></div>
        }
    </div>
</div>