
@{
    ViewBag.Title = "EnquiryDetails";
    Layout = "~/Views/Shared/Admin_Layout.cshtml";
}
@using Wedding_Planner.Models;
@model IEnumerable<EnquiryMaster>

<script>
    $(document).ready(function () {
        var x = $("#enqDetail").text().trim();
        if (x.length > 0)
            $("#enqDetail").fadeIn(100).delay(2500).fadeOut(1500);
    });
</script>
<style>
    table tr:hover {
        background-color: lightgray;
    }
</style>
<div class="container-fluid">
    <div class="row">
        
        <div class="col-sm-12">
            <h1 align="center" style="color:saddlebrown;font-weight:bold;font-family:'Script MT' ">Enquiry Records</h1>
            <hr style="border-top: 1px solid saddlebrown " />
            <p id="enqDetail" align="center" class="h5 text-center " style="min-height: 20px; width: 100%; padding: 2px; padding-top: 10px; font-size: 20px; font-weight: bold; color: #ae0707;display:none;">@TempData["Message"]</p>

            <table border="1" width="100%">
                <tr style="background-color:saddlebrown; color:white;text-align:center; height:45px;" align="center">
                    <th style="text-align:center">SNO</th>

                    <th style="text-align:center">&nbsp;&nbsp;ID&nbsp;&nbsp; </th>
                    <th style="text-align:center">Name</th>
                    <th style="text-align:center">Email ID</th>
                    <th style="text-align:center">Mobile No</th>
                    <th style="text-align:center">Message </th>
                    <th style="text-align:center">Date & Time</th>
                    <th style="text-align:center">Manage Record</th>



                </tr>
                @{
                    int sno = 1;
                    foreach (EnquiryMaster tc in Model)
                    {
                                <tr style="height:40px;">
                                    <td style="text-align:center">@sno</td>
                                    <td style="text-align:center">@tc.Enquiry_Id</td>
                                    <td style="text-align:center">@tc.Name</td>
                                    <td>@tc.EmailId</td>
                                    <td style="text-align:center">@tc.MobileNo</td>
                                    <td>@tc.Enquiry_Message</td>
                                    <td style="text-align:center">@tc.Enquiry_DateTime</td>
                                    <td style="text-align:center">
                                        <a href="@Url.Action("DeleteEnquieryDetails","Admin" , new { eqid = tc.Enquiry_Id })"><i class="fa fa-trash" aria-hidden="true" style="color:saddlebrown;font-size:25px;"></i></a>
                                    </td>
                                   
                                </tr>
                        sno++;
                    }
                }
            </table>
            <br />

        </div>

    </div>
</div>
