
@{
    ViewBag.Title = "UserProfile";
    Layout = "~/Views/Shared/User_Layout.cshtml";
}
@using Wedding_Planner.Models
@model UserMaster 
<style>


    .card .avatar {
        width: 30px;
        height: 30px;
        overflow: hidden;
        border-radius: 50%;
        margin-right: 5px;
    }

    .card .description {
        font-size: 14px;
        color: #333;
    }

    .card h6 {
        font-size: 12px;
        margin: 0;
    }

    .card .ct-label {
        font-size: 1rem !important;
    }



    .card-user .card-image {
        height: 110px;
    }


    .card-user .author {
        text-align: center;
        text-transform: none;
        margin-top: -70px;
    }

    .card-user .avatar {
        width: 124px;
        height: 124px;
        border: 5px solid #FFFFFF;
        position: relative;
        margin-bottom: 15px;
    }
    

        .card-user .avatar.border-gray {
            border-color: #EEEEEE;
        }
        .form-control{
            border:1px solid #bab3b3;
        }
        .form-control:hover{
            border:1px solid saddlebrown;
        }
</style>
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
                <div class="card" style="box-shadow: 1px 2px 8px 1px lightgray;">
                    <div class="card-header">
                        <h4 class="card-title" align="center" style="color:saddlebrown;"><b>Update Profile</b></h4>
                        
                    </div>
                    <div class="card-body">
                        @using (Html.BeginForm("UserProfile", "Customer", FormMethod.Post, new { enctype = "multipart/form-data" }))
                        {
                            <div class="row" style="padding-left:8px;">
                                <div class="col-md-6 px-1">
                                    <div class="form-group">
                                        <label>User name</label>
                                        @Html.TextBox("Name", Model.Name, new { @class = "form-control", PlaceHolder = "Name" })
                                    </div>
                                </div>
                                <div class="col-md-6 pl-1">
                                    <div class="form-group">
                                        <label>  Gender</label>
                                        <span class="form-control">
                                            @{
                                                string str = Model.Gender.ToUpper();
                                                if (str == "MALE")
                                                {
                                                    <input type="radio" name="Gender" value="Male" checked /><span>&nbsp;&nbsp;Male &emsp;</span>
                                                    <input type="radio" name="Gender" value="Female" /><span>&nbsp;&nbsp;Female &emsp;</span>
                                                }
                                                else
                                                {
                                                    <input type="radio" name="Gender" value="Male" /><span>&nbsp;&nbsp;Male &emsp;</span>
                                                    <input type="radio" name="Gender" value="Female" checked /><span>&nbsp;&nbsp;Female &emsp;</span>
                                                }
                                            }
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 pr-1">
                                    <div class="form-group">
                                        <label>Email Address</label>
                                        @Html.TextBox("EmailId", Model.EmailId, new { type = "email", @class = "form-control", placeholder = "ramkushwaha9555@gmail.com", @readonly = "readonly" })

                                    </div>
                                </div>
                                <div class="col-md-6 pl-1">
                                    <div class="form-group">
                                        <label>Mobile No</label>
                                        @Html.TextBox("MobileNo", Model.MobileNo, new { @class = "form-control", PlaceHolder = "Mobile Number", type = "number" })
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 pr-1">
                                    <div class="form-group">
                                        <label>City</label>
                                        @Html.DropDownList("Related_City_Id", null, new { @class = "form-control", placeholder = "Select City" })
                                    </div>
                                </div>
                                <div class="col-md-6 px-1">
                                    <div class="form-group">
                                        <label>Area</label>
                                        @Html.DropDownList("Related_Area_Id", null, new { @class = "form-control", placeholder = "Select Area" })
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>Address</label>
                                        @Html.TextArea("Address",Model.Address, new { @class = "form-control", PlaceHolder = "Address", rows = "3" })
                                    </div>
                                </div>
                            </div>
                            
                            <input type="file" name="New_Pic" id="NewPic" style="display:none;" />
                            <div class="row">
                                <div class="col-sm-9"></div>
                                <div class="col-sm-3">  <input type="submit" class="btn btn-info btn-fill pull-right" value="Update Profile" style="border-radius:5px;" /></div>
                            </div>


                        }
                    </div>
                </div><br />
            </div>
            <div class="col-md-4">
                <div class="card card-user">
                    <div class="card-image">
                        <img src="~/Content/images/slides/dash.jpg" alt="...">
                    </div>
                    <div class="card-body">
                        <div class="author">
                            <a href="#">
                                <img id="Cur_User_Pic" class="avatar border-gray" src="~/Content/User_Profile_Pics/@ViewBag.UserPicName" alt="...">
                                <i id="changePic" class="fa fa-camera" style="color:black;position:relative;top:100%;right:8%;display:none;" title="Choose a new picture"></i>

                                <h5 class="title">Hi @Model.Name</h5>
                            </a>
                            <p class="description">
                                Welcome to Real Time Wedding Planner !!
                            </p>
                        </div>
                        <p id="preprofile" align="center" class="h5 text-center " style="min-height:20px;width:100%;padding:2px;display:none;color:saddlebrown;">
                            @ViewBag.Message
                        </p>
                    </div>
                    <hr>
                    <div class="button-container mr-auto ml-auto">
                        <button href="#" class="btn btn-simple btn-link btn-icon">
                            <i class="fa fa-facebook-square" style="color:saddlebrown"></i>
                        </button>
                        <button href="#" class="btn btn-simple btn-link btn-icon">
                            <i class="fa fa-twitter" style="color:saddlebrown"></i>
                        </button>
                        <button href="#" class="btn btn-simple btn-link btn-icon">
                            <i class="fa fa-google-plus-square" style="color:saddlebrown"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        $("#Related_City_Id").change(function () {

            var cid = $(this).val();
            $.getJSON("/Customer/GetAreaUsingAJAX", { CityId: cid }, function (data) {
                var items = "<option value=''>Select Area</option>";
                $.each(data, function (index, area) {
                    items = items + "<option value='" + area.Area_Id + "'>" + area.Area_Name + "</option>";
                });
                $("#Related_Area_Id").html(items);
            });
        });

        $("#Cur_User_Pic").mouseover(function () {
            $("#changePic").show("fast");
            $(this).css("webkit-filter", "blur(1px)");
        });
        $("#Cur_User_Pic").mouseout(function () {
            $("#changePic").hide("fast");
            $(this).css("webkit-filter", "blur(0px)");
        });
        $("#Cur_User_Pic").click(function () {
            $("#NewPic").trigger("click");
        });
        $("#NewPic").change(function () {
            $("#pfile").remove();
            var fname = $(this).val().substr($(this).val().lastIndexOf('\\')+1);
            var content = "<p id='pfile'><span>Selected File is :</span>" + fname + "</p>";
            $("#changePic").after(content);
        });

        var x = $("#preprofile").text().trim();
        if (x.length > 0)
            $("#preprofile").fadeIn(150).delay(3500).fadeOut(2500);
    });
</script>

 
