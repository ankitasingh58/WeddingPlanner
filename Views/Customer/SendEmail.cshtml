
@{
    ViewBag.Title = "SendEmail";
    Layout = "~/Views/Shared/User_Layout.cshtml";
}
<style>
    .btn-grad {
        background-image: linear-gradient(to right, #603813 0%, #b29f94 51%, #603813 100%);
        height:45px;
        width:200px;
        text-align: center;
        text-transform: uppercase;
        transition: 0.4s;
        background-size: 200% auto;
        color: white;
        box-shadow: 0 0 20px #eee;
        border-radius:40px;
        display: block;
        cursor:pointer;
        border:none;
    }

        .btn-grad:hover {
            background-position: right center; /* change the direction of the change here */
            color: #fff;
            text-decoration: none;
        }
</style>

<script>
    $(document).ready(function () {
        var x = $("#premail").text().trim();
        if (x.length > 0)
            $("#premail").fadeIn(150).delay(3500).fadeOut(2500);
    });
</script>
<div class="container-fluid" style="background-image:url('/Content/images/dm.jpeg');background-repeat:no-repeat;background-size:cover">
    <p id="premail" align="center" class="h5 text-center " style="min-height:20px;width:100%;padding:2px;color:saddlebrown;display:none;">
        @ViewBag.Message
    </p>
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6 pb-5" style="margin-top:56px;margin-bottom:0px;">
            <p id="premail" align="center" class="h5 text-center " style="min-height:20px;width:100%;padding:2px;color:saddlebrown;display:none;">
                @ViewBag.Message
            </p>
            <!--<form action="mail.php" method="post">-->
            @using (Html.BeginForm("SendEmail", "Customer", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="card rounded-0" style="border: 1px solid saddlebrown ">
                    <div class="card-header p-0">
                        <div class=" text-white text-center py-2" style="background-color: #8b45139b;height:50px;">
                            <h3 style="font-size:25px;font-weight:bold;margin-top:2px;"><i class="fa fa-envelope"></i>&emsp;Send Email</h3>
                            <!--<p class="m-0">Con gusto te ayudaremos</p> -->
                        </div>
                    </div>
                    <div class="card-body p-3">
                        <!--Body-->
                        <div class="form-group">
                            <div class="input-group mb-2" style="margin-top:20px;">
                                <div class="input-group-prepend">
                                    <div class="input-group-text"><i class="fa fa-user" style="font-size: 30px; color: #8b45139b"></i></div>
                                </div>&emsp;&emsp;
                                <!-- <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Enter the Name" required>
                           <input type="email" class="form-control" id="nombre" name="email" placeholder="Email" required>
                        <textarea class="form-control" placeholder="Message" required></textarea>-->
                                @Html.TextBox("EmailId", null, new { placeholder = "emailId", @class = "form-control", type="text" })
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="input-group mb-2">
                                <div class="input-group-prepend">
                                    <div class="input-group-text"><i class="fa fa-book" aria-hidden="true" style="font-size: 30px; color: #8b45139b"></i></div>
                                </div>&emsp;&emsp;
                                @Html.TextBox("Subject", null, new { placeholder = "subject mail", @class = "form-control", type = "text" })
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="input-group mb-2">
                                <div class="input-group-prepend">
                                    <div class="input-group-text"><i class="fa fa-comment" style="font-size: 30px; color: #8b45139b"></i></div>
                                </div>&emsp;&emsp;

                                @Html.TextArea("Message", new { placeholder = "Message" + "", @class = "form-control", style = "min-height:60px;" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-3"></div>
                            <div class="col-sm-6 text-center" style="margin-top:20px;margin-bottom:11px;">
                                <input type="submit" value="Send Email" class="btn btn-grad" id="SendEmail">
                            </div>
                            <div class="col-sm-3"></div>
                        </div>
                    </div>

                </div>
            }



        </div>
    </div>
</div>