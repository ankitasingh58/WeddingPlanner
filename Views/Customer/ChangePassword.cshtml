
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/User_Layout.cshtml";
}


<style>
    .btn-grad {
        background-image: linear-gradient(to right, #be5e19 0%, #599ca0 51%,#b7835d 100%);
        margin: 10px;
        text-align: center;
        text-transform: uppercase;
        transition: 0.5s;
        background-size: 200% auto;
        color: white;
        box-shadow: 0 0 20px #eee;
        border-radius: 5px;
        display: block;
        cursor: pointer;
    }

        .btn-grad:hover {
            background-position: right center; /* change the direction of the change here */
            color: #fff;
            text-decoration: none;
        }

    .form-control {
        margin-bottom: 20px;
    }
</style>
<script>
    $(document).ready(function () {
        var x = $("#precon").text().trim();
        if (x.length > 0)
            $("#precon").fadeIn(150).delay(3500).fadeOut(2500);
    });
</script>
<div class="container" style="background-image:url('/Content/images/slides/login2.jpg'); background-size:cover; background-repeat:no-repeat;">

    <div class="row" style="min-height: 500px;">
        <div class="col-sm-4"></div>

        <div class="col-sm-4" style=" background-color:#ffffff77; padding-top:5px;margin-top:30px; margin-bottom:70px;">
            <h2 style="color: #be5e19; text-align: center; font-family: Script MT;"><i class="fa fa-lock"></i>&nbsp;&nbsp;Change Password</h2>
            <p id="precon" align="center" class="h5 text-center " style="min-height:20px;width:100%;padding:2px;display:none;color:saddlebrown;">  @ViewBag.Message</p>
            @using (Html.BeginForm("ChangePassword", "Customer", FormMethod.Post))
            {
                <div class="row" style="padding:25px 15px 10px 10px;">
                    <div class="col-sm-12">
                        @Html.Password("Pass", null, new { placeholder = "Current Password", @class = "form-control" })
                    </div>


                    <div class="col-sm-12">
                        @Html.Password("NewPass", null, new { placeholder = "New Password", @class = "form-control" })
                    </div>
                    <div class="col-sm-12">
                        @Html.Password("ConfNewPass", null, new { placeholder = "Confirm Password", @class = "form-control" })
                    </div>
                    <div class="col-sm-2"></div>
                    <div class="col-sm-8">
                        <input type="submit" class="btn-grad form-control" value="Change Password" style="border-radius:20px; font-weight:bold;" id="btnChangePass" />
                    </div>
                    <div class="col-sm-2"></div>
                </div>
            }
        </div>


        <div class="col-sm-4"></div>
    </div>
</div>

