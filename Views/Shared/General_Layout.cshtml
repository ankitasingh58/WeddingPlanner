        }
    </style>
    <script>
        $(document).ready(function () {

            $("#btnSend").click(function () {

                var status = true;
                var name, email, phone, enqmsg;
                name = $("#enqname").val().trim();
                email = $("#enqemail").val().trim();
                phone = $("#enqmob").val().trim();
                enqmsg = $("#enqmsg").val().trim();

                //To clear erroror message

                $(".error").remove();

                // TO validate name
                if (name.length == 0) {
                    $("#enqname").after("<span class='error'>Please enter your name</span>");
                    status = false;
                }
                else if (name.length < 3) {
                    $("#enqname").after("<span class='error'>Please enter a valid name</span>");
                    status = false;
                }
                // to validate email
                if (email.length == 0) {
                    $("#enqemail").after("<span class='error'>Please enter your email id</span>");
                    status = false;
                }
                else if (email.length != 0) {
                    var ch;
                    ch = email.substring(email.lastIndexOf('.')).toUpperCase();
                    if (!(ch == '.COM' || ch == '.IN')) {
                        $("#enqemail").after("<span class='error'>Please enter valid email id</span>");
                        status = false;
                    }
                }
                // to validate mobile no
                if (phone.length == 0) {
                    $("#enqmob").after("<span class='error'>Please enter your mobile no</span>");
                    status = false;
                }
                else if (phone.length != 10) {
                    $("#enqmob").after("<span class='error'>Mobile number must have 10 digite</span>");
                    status = false;
                }
                else {
                    var digit = parseInt(phone.charAt(0));
                    if (!(digit >= 6 && digit <= 9)) {
                        $("#enqmob").after("<span class='error'>please enter a valide mobile no</span>");
                        status = false;
                    }
                }
                // to validate msg
                if (enqmsg.length == 0) {
                    $("#enqmsg").after("<span class='error'>please enter your queiry..</span>");
                    status = false;
                }
                else if (enqmsg.length < 10) {
                    $("#enqmsg").after("<span class='error'>Please enter complete queiry</span>");
                    status = false;
                }
                return status;
            });

            var x = $("#prenq").text().trim();
            if (x.length > 0)
                $("#prenq").fadeIn(150).delay(3500).fadeOut(2500);
        });
       
    </script>
